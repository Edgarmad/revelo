---
import Button from '@/components/common/Button.astro';
---

<section class="rounded-[2rem] bg-aqua p-8 text-ink md:p-12">
  <div class="grid gap-8 md:grid-cols-[1fr_auto] md:items-center">
    <div>
      <p class="text-sm font-extrabold uppercase tracking-[0.22em]">Asesoria personalizada</p>
      <h2 class="mt-3 font-display text-3xl font-bold tracking-tight md:text-5xl">Elige material, color y configuracion con ayuda especializada.</h2>
      <p class="mt-4 max-w-2xl text-ink/75">Solicita informacion, cotizacion o una recomendacion para transformar tu terraza, jardin o proyecto comercial.</p>
    </div>
    <Button href="/contact/" variant="dark">Contactar</Button>
  </div>
</section>
