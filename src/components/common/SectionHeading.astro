---
interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
  align?: 'left' | 'center';
}

const { eyebrow, title, description, align = 'left' } = Astro.props;
---

<div class={align === 'center' ? 'mx-auto max-w-3xl text-center' : 'max-w-3xl'}>
  {eyebrow && <p class="mb-3 text-sm font-bold uppercase tracking-[0.22em] text-aqua">{eyebrow}</p>}
  <h2 class="font-display text-3xl font-semibold tracking-tight text-ink sm:text-4xl lg:text-5xl">{title}</h2>
  {description && <p class="mt-4 text-base leading-7 text-muted sm:text-lg">{description}</p>}
</div>
