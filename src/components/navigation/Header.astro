---
import { navItems } from '@/data/siteContent';
import Container from '@/components/common/Container.astro';
import { ChevronDown, Menu, Search, ShoppingBag, X } from 'lucide-astro';
import { getAllCategories } from '@/services/categoryService';
import { getFeaturedProducts } from '@/services/productService';
import logoSrc from '@/styles/images/Logo Mila.svg';

const menuCategories = getAllCategories();
const furnitureCategories = menuCategories.filter((category) => ['ratan', 'plastico'].includes(category.slug));
const productCategories = menuCategories.filter((category) => ['plantas', 'aluminio', 'ratan', 'plastico', 'outlet'].includes(category.slug));
const menuProducts = getFeaturedProducts(4);
---

<header class="sticky top-0 z-50 bg-white shadow-sm">
  <div class="bg-ink py-2 text-white">
    <Container class="flex items-center justify-center gap-3 overflow-hidden whitespace-nowrap text-xs font-bold">
      <span>Oferta de verano - Hasta 50% de descuento</span>
      <a class="rounded-pill bg-aqua px-4 py-1 text-ink" href="/products/">Ver ofertas</a>
    </Container>
  </div>
  <Container class="grid min-h-[56px] grid-cols-[48px_minmax(0,1fr)_96px] items-center gap-2 bg-white shadow-[0_6px_14px_rgb(35_31_28/0.12)] lg:min-h-[82px] lg:grid-cols-[188px_minmax(0,1fr)_128px] lg:gap-4 lg:shadow-none">
    <button class="grid h-11 w-11 place-items-center justify-self-start text-ink lg:hidden" type="button" data-menu-toggle aria-expanded="false" aria-controls="mobile-menu" aria-label="Abrir menú"><Menu size={25} /></button>
    <a href="/" class="inline-flex items-center justify-self-center lg:justify-self-start" aria-label="Milapro Home">
      <img class="h-auto w-[78px] lg:w-[188px] lg:max-w-[42vw]" src={logoSrc} alt="Milapro Home" width="188" height="25" />
    </a>
    <nav class="hidden items-center gap-[34px] text-sm font-bold text-[#332b1e] lg:flex lg:justify-self-center" aria-label="Navegación principal">
      {
        navItems.map((item) => {
          if (item.label === 'Muebles para exterior') {
            return (
              <div class="py-8" data-mega-item>
                <a class="inline-flex items-center gap-1 transition hover:text-aqua focus-visible:text-aqua" href={item.href} data-mega-trigger>
                  {item.label}
                  <ChevronDown class="transition" size={14} data-mega-chevron />
                </a>
                <div class="mega-menu-panel pointer-events-none absolute left-0 top-full w-full translate-y-2 border-t border-ink/10 bg-white opacity-0 shadow-2xl transition duration-200" data-mega-panel>
                  <Container class="grid gap-12 py-12 lg:grid-cols-[0.95fr_1.05fr]">
                    <div>
                      <p class="text-sm font-black uppercase tracking-[0.18em] text-aqua">Muebles para exterior</p>
                      <h2 class="mt-4 font-display text-5xl font-light uppercase tracking-wide text-ink">Compra por categoría</h2>
                      <div class="mt-8 flex flex-wrap gap-3">
                        {furnitureCategories.map((category, index) => (
                          <a class={`rounded-pill border px-5 py-2 text-xs font-semibold transition ${index === 0 ? 'border-aqua bg-aqua text-ink' : 'border-ink/25 hover:border-aqua hover:text-aqua'}`} href={`/categories/${category.slug}/`}>
                            {category.name}
                          </a>
                        ))}
                      </div>
                    </div>
                    <div class="grid gap-4 sm:grid-cols-2">
                      {furnitureCategories.map((category) => (
                        <a class="group/card" href={`/categories/${category.slug}/`}>
                          <img class="aspect-[1.35/1] w-full rounded-xl bg-sand object-cover transition group-hover/card:scale-[1.02]" src={category.image} alt={category.name} loading="lazy" width="500" height="370" />
                          <p class="mt-2 text-center text-xs font-semibold text-muted">{category.name}</p>
                        </a>
                      ))}
                    </div>
                  </Container>
                </div>
              </div>
            );
          }

          if (item.label === '🔥 Productos') {
            return (
              <div class="py-8" data-mega-item>
                <a class="inline-flex items-center gap-1 transition hover:text-aqua focus-visible:text-aqua" href={item.href} data-mega-trigger>
                  {item.label}
                  <ChevronDown class="transition" size={14} data-mega-chevron />
                </a>
                <div class="mega-menu-panel pointer-events-none absolute left-0 top-full w-full translate-y-2 border-t border-ink/10 bg-white opacity-0 shadow-2xl transition duration-200" data-mega-panel>
                  <Container class="grid gap-12 py-12 lg:grid-cols-[0.95fr_1.05fr]">
                    <div>
                      <p class="text-sm font-black uppercase tracking-[0.18em] text-aqua">Productos</p>
                      <h2 class="mt-4 font-display text-5xl font-light uppercase tracking-wide text-ink">Colecciones destacadas</h2>
                      <div class="mt-8 grid max-w-xl gap-6">
                        {productCategories.map((category) => (
                          <a class="flex items-center justify-between border-b border-ink/10 pb-5 text-3xl font-light uppercase tracking-wide text-ink transition hover:text-aqua" href={`/categories/${category.slug}/`}>
                            {category.name}
                            <span class="grid h-9 w-9 place-items-center rounded-full border border-ink/30 text-xl leading-none">↗</span>
                          </a>
                        ))}
                      </div>
                    </div>
                    <div class="grid gap-4 sm:grid-cols-2">
                      {menuProducts.map((product) => (
                        <a class="group/card" href={`/products/${product.slug}/`}>
                          <img class="aspect-[1.35/1] w-full rounded-xl bg-sand object-cover transition group-hover/card:scale-[1.02]" src={product.mainImage} alt={product.name} loading="lazy" width="500" height="370" />
                          <p class="mt-2 text-center text-xs font-semibold text-muted">{product.name}</p>
                        </a>
                      ))}
                    </div>
                  </Container>
                </div>
              </div>
            );
          }

          return (
            <a class="transition hover:text-cocoa" href={item.href}>
              {item.label}
            </a>
          );
        })
      }
    </nav>
    <a class="hidden h-11 items-center justify-center rounded-pill bg-aqua px-6 text-sm font-black uppercase text-ink transition hover:bg-ink hover:text-white lg:inline-flex" href="/contact/">Contactar</a>
    <div class="flex items-center justify-self-end lg:hidden">
      <a class="grid h-11 w-11 place-items-center text-ink" href="/products/" aria-label="Buscar productos"><Search size={22} /></a>
      <a class="grid h-11 w-11 place-items-center text-ink" href="/contact/" aria-label="Solicitar productos"><ShoppingBag size={22} /></a>
    </div>
  </Container>
  <div id="mobile-menu" class="fixed inset-0 top-0 z-[60] hidden bg-ink/45 pt-[33vh] lg:hidden" data-mobile-menu>
    <div class="mx-6 flex min-h-[62vh] flex-col overflow-hidden rounded-t-xl bg-white shadow-2xl">
      <div class="flex min-h-[60px] items-center justify-center gap-3 bg-[#f7f7f7] text-sm uppercase text-ink">
        <button class="inline-flex items-center gap-3" type="button" data-menu-close aria-label="Cerrar menú"><X size={28} /> Close</button>
      </div>
      <nav class="grid gap-4 px-6 py-8 text-xl font-black text-ink" aria-label="Navegación móvil" data-mobile-menu-main>
        <button class="flex items-center justify-between text-left" type="button" data-mobile-submenu-open="products"><span>Muebles para exterior</span><span class="grid h-6 min-w-16 place-items-center rounded-pill bg-aqua text-2xl font-light leading-none">→</span></button>
        <a class="flex items-center justify-between" href="/products/"><span>🔥 Productos</span><span class="grid h-6 min-w-16 place-items-center rounded-pill bg-aqua text-2xl font-light leading-none">→</span></a>
        <a href="/#reviews">Opiniones</a>
        <a class="flex items-center justify-between" href="/about/"><span>Acerca de</span><span class="grid h-6 min-w-16 place-items-center rounded-pill bg-aqua text-2xl font-light leading-none">→</span></a>
        <a href="/contact/">Contacto</a>
      </nav>
      <nav class="hidden px-6 py-8 text-ink" aria-label="Categorías móviles" data-mobile-menu-submenu>
        <button class="mb-5 inline-flex items-center gap-3 text-base font-bold text-muted" type="button" data-mobile-submenu-back><span class="text-2xl leading-none">‹</span> Muebles para exterior</button>
        <div class="grid gap-7">
          {productCategories.map((category) => (
            <a class="flex items-center justify-between text-2xl font-black uppercase" href={`/categories/${category.slug}/`}>
              {category.name}
              <span class="grid h-9 w-9 place-items-center rounded-full border border-ink/80 text-xl font-light leading-none">↗</span>
            </a>
          ))}
        </div>
      </nav>
      <div class="mt-auto border-t border-ink/10 px-6 py-8 text-center text-sm text-muted">ventas@milaprohome.com</div>
    </div>
  </div>
</header>

<script>
  const toggle = document.querySelector<HTMLButtonElement>('[data-menu-toggle]');
  const close = document.querySelector<HTMLButtonElement>('[data-menu-close]');
  const menu = document.querySelector<HTMLElement>('[data-mobile-menu]');
  const megaItems = document.querySelectorAll<HTMLElement>('[data-mega-item]');
  let megaCloseTimer: ReturnType<typeof setTimeout> | undefined;

  const closeMegaMenus = () => {
    megaItems.forEach((item) => {
      item.querySelector<HTMLElement>('[data-mega-trigger]')?.classList.remove('text-aqua');
      item.querySelector<HTMLElement>('[data-mega-chevron]')?.classList.remove('rotate-180');
      item.querySelector<HTMLElement>('[data-mega-panel]')?.classList.remove('mega-menu-panel-open');
    });
  };

  const openMegaMenu = (item: HTMLElement) => {
    window.clearTimeout(megaCloseTimer);
    closeMegaMenus();
    item.querySelector<HTMLElement>('[data-mega-trigger]')?.classList.add('text-aqua');
    item.querySelector<HTMLElement>('[data-mega-chevron]')?.classList.add('rotate-180');
    item.querySelector<HTMLElement>('[data-mega-panel]')?.classList.add('mega-menu-panel-open');
  };

  const scheduleMegaClose = () => {
    window.clearTimeout(megaCloseTimer);
    megaCloseTimer = window.setTimeout(closeMegaMenus, 500);
  };

  megaItems.forEach((item) => {
    item.addEventListener('mouseenter', () => openMegaMenu(item));
    item.addEventListener('mouseleave', scheduleMegaClose);
    item.addEventListener('focusin', () => openMegaMenu(item));
    item.addEventListener('focusout', (event) => {
      if (!item.contains(event.relatedTarget as Node | null)) scheduleMegaClose();
    });
  });

  const mobileMainMenu = menu?.querySelector<HTMLElement>('[data-mobile-menu-main]');
  const mobileSubmenu = menu?.querySelector<HTMLElement>('[data-mobile-menu-submenu]');

  const setOpen = (open: boolean) => {
    menu?.classList.toggle('hidden', !open);
    toggle?.setAttribute('aria-expanded', String(open));
    document.documentElement.classList.toggle('overflow-hidden', open);
    if (!open) {
      mobileSubmenu?.classList.add('hidden');
      mobileMainMenu?.classList.remove('hidden');
    }
  };
  toggle?.addEventListener('click', () => setOpen(menu?.classList.contains('hidden') ?? true));
  close?.addEventListener('click', () => setOpen(false));

  menu?.querySelector<HTMLElement>('[data-mobile-submenu-open]')?.addEventListener('click', () => {
    mobileMainMenu?.classList.add('hidden');
    mobileSubmenu?.classList.remove('hidden');
  });
  menu?.querySelector<HTMLElement>('[data-mobile-submenu-back]')?.addEventListener('click', () => {
    mobileSubmenu?.classList.add('hidden');
    mobileMainMenu?.classList.remove('hidden');
  });
</script>

<style>
  .mega-menu-panel-open {
    pointer-events: auto;
    opacity: 1;
    transform: translateY(0);
  }
</style>
