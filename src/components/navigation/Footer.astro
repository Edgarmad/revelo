---
import Container from '@/components/common/Container.astro';
import Newsletter from '@/components/sections/Newsletter.astro';
import { Facebook, Instagram, Youtube } from 'lucide-astro';
---

<footer class="mt-20">
  <Container>
    <div class="relative rounded-t-[2rem] bg-ink px-8 pb-12 pt-20 text-white md:px-14">
      <div class="absolute -top-10 left-8 rounded-[1.5rem] bg-aqua px-12 py-5 font-display text-3xl font-black uppercase leading-none text-teal-900 md:left-36">Linsy<br />Home</div>
      <div class="grid gap-10 md:grid-cols-4">
        <div><h3 class="font-bold uppercase tracking-wide">Shop</h3><ul class="mt-6 grid gap-3 text-sm text-white/75"><li>Reclining Couch</li><li>Rubik V</li><li>Rubik III</li><li>Cabik I</li></ul></div>
        <div><h3 class="font-bold uppercase tracking-wide">Explore</h3><ul class="mt-6 grid gap-3 text-sm text-white/75"><li><a href="/about/">About Us</a></li><li>Product Design</li><li>Join Us</li><li>Affiliate</li></ul></div>
        <div><h3 class="font-bold uppercase tracking-wide">Support</h3><ul class="mt-6 grid gap-3 text-sm text-white/75"><li><a href="/#reviews">Reviews</a></li><li>Price Guarantee</li><li>Track My Order</li><li>User Support</li></ul></div>
        <div><h3 class="font-bold uppercase tracking-wide">Policy</h3><ul class="mt-6 grid gap-3 text-sm text-white/75"><li>Return & Refund Policy</li><li>Shipping Policy</li><li>Privacy Policy</li><li>Warranty Policy</li></ul></div>
      </div>
    </div>
  </Container>
  <div class="bg-sand py-8">
    <Container class="grid gap-6 md:grid-cols-[1fr_1fr_auto] md:items-center">
      <Newsletter />
      <p class="text-sm text-muted">Customer Service Email: service@linsyhome.com<br />Address: 50 N HILL AVE #303 PASADENA, CA 91106</p>
      <div class="flex gap-5 text-ink"><Facebook size={20} /><Instagram size={20} /><Youtube size={20} /></div>
    </Container>
  </div>
</footer>
