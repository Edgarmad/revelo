---
import Container from '@/components/common/Container.astro';
import Newsletter from '@/components/sections/Newsletter.astro';
import { Facebook, Instagram } from 'lucide-astro';
import logoSrc from '@/styles/images/Logo Mila.svg';
---

<footer class="mt-20 lg:mt-28">
  <div class="relative overflow-visible rounded-t-[2.2rem] bg-ink px-5 pb-4 pt-24 text-white sm:px-10 lg:rounded-t-[3rem] lg:px-16 lg:pb-24 lg:pt-32">
    <div class="absolute -top-6 left-1/2 flex min-h-[50px] w-[130px] -translate-x-1/2 items-center justify-center rounded-pill bg-aqua px-5 lg:-top-[38px] lg:left-28 lg:min-h-[94px] lg:w-[228px] lg:translate-x-0 lg:rounded-[1.4rem]">
      <img class="h-auto w-[90px] lg:w-[188px] lg:max-w-[58vw]" src={logoSrc} alt="Milapro Home" width="188" height="25" />
    </div>
    <div class="grid gap-0 lg:grid-cols-4 lg:gap-24">
      <div class="border-b border-white/60 py-4 lg:border-0 lg:py-0"><h3 class="flex items-center justify-between text-base font-medium uppercase tracking-wide lg:block lg:text-xl">Catálogo <span class="grid h-5 w-5 place-items-center rounded-full bg-aqua text-ink lg:hidden">+</span></h3><ul class="mt-12 hidden gap-5 text-base text-white lg:grid"><li class="footer-link-marker footer-link-marker-orange">Ratán sintético</li><li class="footer-link-marker footer-link-marker-orange">Plástico</li><li class="footer-link-marker footer-link-marker-orange">Aluminio</li><li class="footer-link-marker footer-link-marker-orange">Sombrillas</li></ul></div>
      <div class="border-b border-white/60 py-4 lg:border-0 lg:py-0"><h3 class="flex items-center justify-between text-base font-medium uppercase tracking-wide lg:block lg:text-xl">Explora <span class="grid h-5 w-5 place-items-center rounded-full bg-aqua text-ink lg:hidden">+</span></h3><ul class="mt-12 hidden gap-5 text-base text-white lg:grid"><li class="footer-link-marker"><a href="/about/">Acerca de</a></li><li class="footer-link-marker">Proyectos a la medida</li><li class="footer-link-marker">Pérgolas</li><li class="footer-link-marker">Plantas</li></ul></div>
      <div class="border-b border-white/60 py-4 lg:border-0 lg:py-0"><h3 class="flex items-center justify-between text-base font-medium uppercase tracking-wide lg:block lg:text-xl">Atención <span class="grid h-5 w-5 place-items-center rounded-full bg-aqua text-ink lg:hidden">+</span></h3><ul class="mt-12 hidden gap-5 text-base text-white lg:grid"><li class="footer-link-marker"><a href="/#reviews">Opiniones</a></li><li class="footer-link-marker">Asesoría personalizada</li><li class="footer-link-marker">Alianzas comerciales</li><li class="footer-link-marker">Soporte al cliente</li></ul></div>
      <div class="border-b border-white/60 py-4 lg:border-0 lg:py-0"><h3 class="flex items-center justify-between text-base font-medium uppercase tracking-wide lg:block lg:text-xl">Políticas <span class="grid h-5 w-5 place-items-center rounded-full bg-aqua text-ink lg:hidden">+</span></h3><ul class="mt-12 hidden gap-5 text-base text-white lg:grid"><li class="footer-link-marker">Garantía</li><li class="footer-link-marker">Envíos</li><li class="footer-link-marker">Privacidad</li><li class="footer-link-marker">Devoluciones</li></ul></div>
    </div>
  </div>
  <div class="bg-white py-8 lg:bg-sand lg:py-10">
    <Container class="grid gap-6 text-center md:grid-cols-[1fr_1fr_auto] md:items-center md:text-left">
      <div class="hidden lg:block"><Newsletter /></div>
      <p class="text-[11px] text-muted lg:text-sm">Correo de atención: ventas@milaprohome.com<br />Muebles para exterior, proyectos a la medida y alianzas comerciales.</p>
      <div class="flex justify-center gap-7 text-ink md:justify-start lg:gap-5">
        <a href="https://www.milaprohome.com/website/social/facebook" target="_blank" rel="noreferrer" aria-label="Facebook de Milapro Home"><Facebook size={20} /></a>
        <a href="https://www.milaprohome.com/website/social/instagram" target="_blank" rel="noreferrer" aria-label="Instagram de Milapro Home"><Instagram size={20} /></a>
      </div>
    </Container>
  </div>
</footer>

<style>
  .footer-link-marker {
    position: relative;
    padding-left: 1.35rem;
  }

  .footer-link-marker::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.62em;
    width: 0.7rem;
    height: 0.22rem;
    border-radius: 999px;
    background: rgb(var(--color-aqua));
  }

  .footer-link-marker-orange::before {
    background: #f97316;
  }
</style>
