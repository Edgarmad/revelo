---
import Container from '@/components/common/Container.astro';
import Newsletter from '@/components/sections/Newsletter.astro';
import { Facebook, Instagram, Youtube } from 'lucide-astro';
---

<footer class="mt-20">
  <Container>
    <div class="relative rounded-t-[2rem] bg-ink px-8 pb-12 pt-20 text-white md:px-14">
      <div class="absolute -top-10 left-8 rounded-[1.5rem] bg-aqua px-12 py-5 font-display text-3xl font-black uppercase leading-none text-teal-900 md:left-36">Milapro<br />Home</div>
      <div class="grid gap-10 md:grid-cols-4">
        <div><h3 class="font-bold uppercase tracking-wide">Catalogo</h3><ul class="mt-6 grid gap-3 text-sm text-white/75"><li>Rattan sintetico</li><li>Plastico</li><li>Aluminio</li><li>Sombrillas</li></ul></div>
        <div><h3 class="font-bold uppercase tracking-wide">Explora</h3><ul class="mt-6 grid gap-3 text-sm text-white/75"><li><a href="/about/">Acerca de</a></li><li>Proyectos a la medida</li><li>Pergolas</li><li>Plantas</li></ul></div>
        <div><h3 class="font-bold uppercase tracking-wide">Atencion</h3><ul class="mt-6 grid gap-3 text-sm text-white/75"><li><a href="/#reviews">Opiniones</a></li><li>Asesoria personalizada</li><li>Alianzas comerciales</li><li>Soporte al cliente</li></ul></div>
        <div><h3 class="font-bold uppercase tracking-wide">Politicas</h3><ul class="mt-6 grid gap-3 text-sm text-white/75"><li>Garantia</li><li>Envios</li><li>Privacidad</li><li>Devoluciones</li></ul></div>
      </div>
    </div>
  </Container>
  <div class="bg-sand py-8">
    <Container class="grid gap-6 md:grid-cols-[1fr_1fr_auto] md:items-center">
      <Newsletter />
      <p class="text-sm text-muted">Correo de atencion: ventas@milaprohome.com<br />Muebles para exterior, proyectos a la medida y alianzas comerciales.</p>
      <div class="flex gap-5 text-ink"><Facebook size={20} /><Instagram size={20} /><Youtube size={20} /></div>
    </Container>
  </div>
</footer>
