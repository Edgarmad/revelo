---
import Container from '@/components/common/Container.astro';
import Newsletter from '@/components/sections/Newsletter.astro';
import { Facebook, Instagram } from 'lucide-astro';
import logoSrc from '@/styles/images/Logo Mila.svg';
---

<footer class="mt-28">
  <div class="relative overflow-visible rounded-t-[3rem] bg-ink px-5 pb-20 pt-28 text-white sm:px-10 lg:px-16 lg:pb-24 lg:pt-32">
    <div class="absolute -top-[38px] left-7 flex min-h-[94px] w-[228px] items-center justify-center rounded-[1.4rem] bg-aqua px-5 sm:left-14 lg:left-28">
      <img class="h-auto w-[188px] max-w-[58vw]" src={logoSrc} alt="Milapro Home" width="188" height="25" />
    </div>
    <div class="grid gap-12 md:grid-cols-2 lg:grid-cols-4 lg:gap-24">
      <div><h3 class="text-xl font-medium uppercase tracking-wide">Catálogo</h3><ul class="mt-12 grid gap-5 text-base text-white"><li class="footer-link-marker footer-link-marker-orange">Ratán sintético</li><li class="footer-link-marker footer-link-marker-orange">Plástico</li><li class="footer-link-marker footer-link-marker-orange">Aluminio</li><li class="footer-link-marker footer-link-marker-orange">Sombrillas</li></ul></div>
      <div><h3 class="text-xl font-medium uppercase tracking-wide">Explora</h3><ul class="mt-12 grid gap-5 text-base text-white"><li class="footer-link-marker"><a href="/about/">Acerca de</a></li><li class="footer-link-marker">Proyectos a la medida</li><li class="footer-link-marker">Pérgolas</li><li class="footer-link-marker">Plantas</li></ul></div>
      <div><h3 class="text-xl font-medium uppercase tracking-wide">Atención</h3><ul class="mt-12 grid gap-5 text-base text-white"><li class="footer-link-marker"><a href="/#reviews">Opiniones</a></li><li class="footer-link-marker">Asesoría personalizada</li><li class="footer-link-marker">Alianzas comerciales</li><li class="footer-link-marker">Soporte al cliente</li></ul></div>
      <div><h3 class="text-xl font-medium uppercase tracking-wide">Políticas</h3><ul class="mt-12 grid gap-5 text-base text-white"><li class="footer-link-marker">Garantía</li><li class="footer-link-marker">Envíos</li><li class="footer-link-marker">Privacidad</li><li class="footer-link-marker">Devoluciones</li></ul></div>
    </div>
  </div>
  <div class="bg-sand py-10">
    <Container class="grid gap-6 md:grid-cols-[1fr_1fr_auto] md:items-center">
      <Newsletter />
      <p class="text-sm text-muted">Correo de atención: ventas@milaprohome.com<br />Muebles para exterior, proyectos a la medida y alianzas comerciales.</p>
      <div class="flex gap-5 text-ink">
        <a href="https://www.milaprohome.com/website/social/facebook" target="_blank" rel="noreferrer" aria-label="Facebook de Milapro Home"><Facebook size={20} /></a>
        <a href="https://www.milaprohome.com/website/social/instagram" target="_blank" rel="noreferrer" aria-label="Instagram de Milapro Home"><Instagram size={20} /></a>
      </div>
    </Container>
  </div>
</footer>

<style>
  .footer-link-marker {
    position: relative;
    padding-left: 1.35rem;
  }

  .footer-link-marker::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.62em;
    width: 0.7rem;
    height: 0.22rem;
    border-radius: 999px;
    background: rgb(var(--color-aqua));
  }

  .footer-link-marker-orange::before {
    background: #f97316;
  }
</style>
