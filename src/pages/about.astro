---
import Button from '@/components/common/Button.astro';
import Container from '@/components/common/Container.astro';
import SectionHeading from '@/components/common/SectionHeading.astro';
import ContactCallout from '@/components/sections/ContactCallout.astro';
import MainLayout from '@/layouts/MainLayout.astro';
---

<MainLayout title="About Us | Linsy Home" description="Historia, posicionamiento y valores visuales del catalogo Linsy Home.">
  <Container class="py-16">
    <div class="grid gap-10 lg:grid-cols-[0.95fr_1.05fr] lg:items-center">
      <div>
        <SectionHeading eyebrow="About us" title="Furniture that makes life better" description="Este MVP visual presenta una marca de catalogo enfocada en muebles modulares, comodidad diaria y una estetica comercial limpia." />
        <Button href="/products/" class="mt-8">Explorar productos</Button>
      </div>
      <img class="aspect-[4/3] rounded-[2rem] object-cover" src="https://images.unsplash.com/photo-1600607687939-ce8a6c25118c?auto=format&fit=crop&w=1200&q=85" alt="Sala moderna con sofa modular" width="1200" height="900" />
    </div>
    <section class="mt-16 grid gap-6 md:grid-cols-3">
      {[
        ['Modularidad real', 'Piezas pensadas para adaptarse a cambios de hogar, familia y rutina.'],
        ['Comodidad premium', 'Proporciones generosas, telas suaves y soporte para uso cotidiano.'],
        ['Catalogo escalable', 'Datos y servicios preparados para conectarse a WordPress Headless en una fase futura.'],
      ].map(([title, text]) => <article class="rounded-soft bg-sand p-8"><h2 class="text-xl font-bold">{title}</h2><p class="mt-3 leading-7 text-muted">{text}</p></article>)}
    </section>
    <div class="mt-16"><ContactCallout /></div>
  </Container>
</MainLayout>
