---
import Button from '@/components/common/Button.astro';
import Container from '@/components/common/Container.astro';
import SectionHeading from '@/components/common/SectionHeading.astro';
import ContactCallout from '@/components/sections/ContactCallout.astro';
import MainLayout from '@/layouts/MainLayout.astro';
---

<MainLayout title="Acerca de | Milapro Home" description="Historia, posicionamiento y valores visuales del catálogo Milapro Home.">
  <Container class="py-16">
    <div class="grid gap-10 lg:grid-cols-[0.95fr_1.05fr] lg:items-center">
      <div>
        <SectionHeading eyebrow="Acerca de" title="Muebles de exterior que transforman espacios" description="Somos una marca especializada en muebles de exterior y sustitutos de materiales, dedicada a crear soluciones elegantes, funcionales y duraderas." />
        <Button href="/products/" class="mt-8">Explorar productos</Button>
      </div>
      <img class="aspect-[4/3] rounded-[2rem] object-cover" src="https://images.unsplash.com/photo-1600607687939-ce8a6c25118c?auto=format&fit=crop&w=1200&q=85" alt="Ambiente exterior con muebles de descanso" width="1200" height="900" />
    </div>
    <section class="mt-16 grid gap-6 md:grid-cols-3">
      {[
        ['Alta durabilidad', 'Materiales resistentes al sol, humedad y uso cotidiano en exterior.'],
        ['Diseño funcional', 'Piezas cómodas y elegantes para terrazas, jardines, hoteles y restaurantes.'],
        ['Proyectos a la medida', 'Alianzas con arquitectos y diseñadores para adaptar cada propuesta a sus necesidades.'],
      ].map(([title, text]) => <article class="rounded-soft bg-sand p-8"><h2 class="text-xl font-bold">{title}</h2><p class="mt-3 leading-7 text-muted">{text}</p></article>)}
    </section>
    <div class="mt-16"><ContactCallout /></div>
  </Container>
</MainLayout>
