---
import Button from '@/components/common/Button.astro';
import Container from '@/components/common/Container.astro';
import SectionHeading from '@/components/common/SectionHeading.astro';
import Breadcrumbs from '@/components/common/Breadcrumbs.astro';
import MainLayout from '@/layouts/MainLayout.astro';
import { blogCards } from '@/data/siteContent';
---

<MainLayout title="Blogs e inspiraciones | Milapro Home" description="Consejos e inspiración para elegir muebles, materiales y soluciones para espacios exteriores.">
  <Container class="py-14">
    <Breadcrumbs items={[{ label: 'Inicio', href: '/' }, { label: 'Blogs e inspiraciones' }]} />
    <section class="mt-8 rounded-[2.4rem] bg-sand p-8 md:p-12">
      <div class="max-w-3xl">
        <SectionHeading eyebrow="Milapro Home" title="Blogs e inspiraciones" description="Guías prácticas para transformar terrazas, jardines y proyectos comerciales con muebles de exterior funcionales y duraderos." />
      </div>
    </section>

    <section class="mt-12 grid gap-8 md:grid-cols-3">
      {blogCards.map((card) => (
        <article class="overflow-hidden rounded-2xl bg-white shadow-sm ring-1 ring-ink/10 transition hover:-translate-y-1 hover:shadow-xl">
          <a href={`/blogs/${card.slug}/`} aria-label={`Leer ${card.title}`}>
            <img class="aspect-[4/3] w-full object-cover" src={card.image} alt={card.title} loading="lazy" width="800" height="600" />
          </a>
          <div class="p-6">
            <p class="text-xs font-semibold uppercase tracking-wide text-cocoa">{card.category}</p>
            <h2 class="mt-3 text-xl font-bold text-ink"><a class="transition hover:text-cocoa" href={`/blogs/${card.slug}/`}>{card.title}</a></h2>
            <p class="mt-3 text-sm leading-6 text-muted">{card.excerpt}</p>
            <Button href={`/blogs/${card.slug}/`} variant="secondary" class="mt-6">Leer más</Button>
          </div>
        </article>
      ))}
    </section>
  </Container>
</MainLayout>
