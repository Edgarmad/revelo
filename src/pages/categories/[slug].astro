---
import Breadcrumbs from '@/components/common/Breadcrumbs.astro';
import Button from '@/components/common/Button.astro';
import Container from '@/components/common/Container.astro';
import SectionHeading from '@/components/common/SectionHeading.astro';
import CategoryCard from '@/components/category/CategoryCard.astro';
import FilterControls from '@/components/filters/FilterControls.astro';
import ProductGrid from '@/components/product/ProductGrid.astro';
import MainLayout from '@/layouts/MainLayout.astro';
import { getAllCategories, getCategoryBySlug, getCategorySlugs } from '@/services/categoryService';
import { getProductsByCategory } from '@/services/productService';

export function getStaticPaths() {
  return getCategorySlugs().map((slug) => ({ params: { slug } }));
}

const category = getCategoryBySlug(Astro.params.slug ?? '');
if (!category) return Astro.redirect('/404/');
const products = getProductsByCategory(category.slug);
const categories = getAllCategories();
const relatedCategories = categories.filter((item) => item.slug !== category.slug).slice(0, 4);
---

<MainLayout title={`${category.name} | Milapro Home`} description={category.description}>
  <section class="relative overflow-hidden">
    <img class="absolute inset-0 h-full w-full object-cover" src={category.image} alt={category.name} width="1600" height="700" />
    <div class="absolute inset-0 bg-black/50"></div>
    <Container class="relative py-24 text-white md:py-32">
      <Breadcrumbs items={[{ label: 'Home', href: '/' }, { label: 'Categorias' }, { label: category.name }]} />
      <p class="mt-10 text-sm font-extrabold uppercase tracking-[0.22em] text-aqua">{category.eyebrow}</p>
      <h1 class="mt-3 font-display text-5xl font-black tracking-tight md:text-7xl">{category.name}</h1>
      <p class="mt-5 max-w-2xl text-lg leading-8 text-white/80">{category.description}</p>
    </Container>
  </section>
  <Container class="py-14">
    <FilterControls categories={categories} />
    <div class="mt-8"><ProductGrid products={products} /></div>
    <section class="mt-16">
      <div class="flex flex-wrap items-end justify-between gap-6"><SectionHeading title="Related categories" description="Explora otras lineas del catalogo visual." /><Button href="/products/" variant="secondary">Todo el catalogo</Button></div>
      <div class="mt-8 grid gap-8 sm:grid-cols-2 lg:grid-cols-4">{relatedCategories.map((item) => <CategoryCard category={item} />)}</div>
    </section>
  </Container>
</MainLayout>
