---
import Button from '@/components/common/Button.astro';
import Container from '@/components/common/Container.astro';
import MainLayout from '@/layouts/MainLayout.astro';
---

<MainLayout title="404 | Milapro Home" description="Página no encontrada en el catálogo visual.">
  <Container class="grid min-h-[60vh] place-items-center py-20 text-center">
    <div class="max-w-2xl">
      <p class="font-display text-8xl font-black text-aqua">404</p>
      <h1 class="mt-4 font-display text-4xl font-bold tracking-tight">Esta pieza no está en el catálogo.</h1>
      <p class="mt-4 text-lg leading-8 text-muted">La ruta no existe o el producto fue movido. Vuelve al catálogo para seguir explorando muebles de exterior.</p>
      <div class="mt-8 flex justify-center gap-3"><Button href="/products/">Ver productos</Button><Button href="/" variant="secondary">Inicio</Button></div>
    </div>
  </Container>
</MainLayout>
