---
import Container from '@/components/common/Container.astro';
import Button from '@/components/common/Button.astro';
import SectionHeading from '@/components/common/SectionHeading.astro';
import CategoryCard from '@/components/category/CategoryCard.astro';
import MainLayout from '@/layouts/MainLayout.astro';
import { getAllCategories, getFeaturedCategories } from '@/services/categoryService';
import { getAllProducts } from '@/services/productService';
import { blogCards, customerReviews } from '@/data/siteContent';
import { CreditCard, RotateCcw, ShieldCheck, ShoppingBag, Truck } from 'lucide-astro';
import bgSrc from '@/styles/images/bg.png';

const categories = getFeaturedCategories(5);
const productCategories = getAllCategories();
const products = getAllProducts();
const initialProductCategory = productCategories[0]?.slug;
const featuredReviews = customerReviews.filter((review) => review.rating === 5);
const instagramReels = [
  { url: 'https://www.instagram.com/milaprohome.mid/reel/DbE5EoXtMei/', thumbnail: '/instagram-reels/reel-01.jpg' },
  { url: 'https://www.instagram.com/milaprohome.mid/reel/Da6HAhoJtuT/', thumbnail: '/instagram-reels/reel-02.jpg' },
  { url: 'https://www.instagram.com/milaprohome.mid/reel/DaLX89wR8Gn/', thumbnail: '/instagram-reels/reel-03.jpg' },
  { url: 'https://www.instagram.com/milaprohome.mid/reel/DTl0X5QD12n/', thumbnail: '/instagram-reels/reel-04.jpg' },
  { url: 'https://www.instagram.com/milaprohome.mid/reel/DUJOXy7kdGP/', thumbnail: '/instagram-reels/reel-05.jpg' },
  { url: 'https://www.instagram.com/milaprohome.mid/reel/DRU30uZgfVq/', thumbnail: '/instagram-reels/reel-06.jpg' },
  { url: 'https://www.instagram.com/milaprohome.mid/reel/DPouY0NklzU/', thumbnail: '/instagram-reels/reel-07.jpg' },
  { url: 'https://www.instagram.com/milaprohome.mid/reel/DPUBKIkjWwX/', thumbnail: '/instagram-reels/reel-08.jpg' },
  { url: 'https://www.instagram.com/milaprohome.mid/reel/DOWnTiViefZ/', thumbnail: '/instagram-reels/reel-09.jpg' },
];
---

<MainLayout title="Milapro Home | Muebles para exterior" description="Catálogo visual de muebles para exterior, ratán sintético, aluminio, plástico, sombrillas, pérgolas y plantas.">
  <section class="relative min-h-[600px] overflow-hidden md:min-h-[720px]">
    <img class="absolute inset-0 h-full w-full object-cover object-center" src={bgSrc} alt="Comedor exterior frente al mar" width="1800" height="1000" />
    <div class="absolute inset-0"></div>
    <Container class="relative grid min-h-[600px] place-items-end pb-14 pt-24 text-center text-white md:min-h-[720px] md:place-items-center md:py-24">
      <div>
        <h1 class="font-display text-6xl font-black uppercase leading-none tracking-tight sm:text-8xl lg:text-9xl">Oferta de verano</h1>
        <p class="mt-2 text-4xl font-light uppercase sm:text-6xl">Hasta 50% de descuento</p>
        <Button href="/products/" class="mt-6">Comprar ahora</Button>
      </div>
    </Container>
  </section>

  <Container>
    <section class="grid grid-cols-4 border-b border-ink/10 py-7 lg:py-10">
      {[
        { icon: Truck, label: 'Envío disponible' },
        { icon: ShieldCheck, label: 'Garantía de tres años' },
        { icon: CreditCard, label: 'Pagos en cuotas' },
        { icon: RotateCcw, label: 'Asesoría postventa' },
      ].map((benefit) => (
        <div class="flex flex-col items-center gap-3 border-r border-ink/20 px-2 py-2 text-center last:border-r-0 lg:py-6">
          <benefit.icon class="text-aqua" size={30} />
          <p class="text-[10px] font-medium uppercase leading-4 tracking-normal text-muted lg:text-sm lg:font-semibold lg:tracking-wide">{benefit.label}</p>
        </div>
      ))}
    </section>

    <section class="relative left-1/2 w-screen -translate-x-1/2 overflow-hidden px-5 py-10 sm:px-8 lg:px-12 lg:py-14">
      <h2 class="font-display text-[28px] font-light leading-tight tracking-tight text-ink sm:text-5xl lg:text-6xl">Milapro Home - Transforma tu exterior</h2>
      <p class="mt-4 text-sm font-light uppercase tracking-wide text-cocoa sm:text-xl lg:mt-10">Compra por categoría</p>
      <div class="mt-4 flex snap-x snap-mandatory gap-2 overflow-x-auto pb-2 sm:grid sm:grid-cols-2 sm:gap-6 lg:grid-cols-5 xl:gap-10">
        {categories.map((category) => <CategoryCard category={category} />)}
      </div>
    </section>

    <section class="pb-14 lg:pb-20" data-product-section>
      <div class="flex items-center justify-between gap-4">
        <div>
          <h2 class="font-display text-[26px] font-light uppercase tracking-[0.04em] text-ink lg:text-6xl lg:tracking-[0.08em]">Nuestros productos</h2>
          <p class="mt-3 hidden max-w-2xl leading-7 text-muted lg:block">Colecciones para terrazas, jardines y proyectos comerciales con materiales resistentes al exterior.</p>
        </div>
        <Button href="/products/" class="min-h-9 px-5 text-xs lg:min-h-11 lg:px-6 lg:text-sm">Ver todo</Button>
      </div>

      <div class="mt-5 flex snap-x gap-3 overflow-x-auto pb-2 lg:mt-8 lg:flex-wrap" role="tablist" aria-label="Filtrar productos por categoria">
        {productCategories.map((category, index) => (
          <button class={`shrink-0 rounded-pill border px-5 py-2 text-xs font-semibold transition ${index === 0 ? 'border-aqua bg-aqua text-ink' : 'border-ink/30 bg-white text-muted hover:border-aqua hover:text-ink'}`} type="button" data-product-filter={category.slug} aria-selected={String(index === 0)}>
            {category.name}
          </button>
        ))}
      </div>

      <div class="relative left-1/2 mt-8 w-screen -translate-x-1/2 overflow-hidden">
        <div class="product-carousel flex snap-x snap-mandatory gap-8 overflow-x-auto px-5 pb-3 scroll-smooth lg:px-[max(2rem,calc((100vw-1180px)/2))]" tabindex="0" aria-label="Carrusel de productos">
          {products.map((product) => {
            const isInitial = initialProductCategory ? product.categories.includes(initialProductCategory) : true;

            return (
              <article class={`product-carousel-card group w-[78vw] max-w-[410px] shrink-0 snap-center rounded-[1.4rem] bg-[#f1f1f1] p-3 sm:w-[360px] lg:p-4 ${isInitial ? '' : 'hidden'}`} data-product-card data-product-categories={product.categories.join(' ')}>
                <a class="block" href={`/products/${product.slug}/`}>
                  <div class="relative overflow-hidden rounded-xl bg-white">
                    {product.badge && <span class="absolute left-3 top-3 z-10 bg-red-500 px-3 py-1 text-xs font-black text-white">{product.badge}</span>}
                    <img class="aspect-[1.24/1] w-full object-cover transition duration-500 group-hover:scale-105" src={product.mainImage} alt={product.name} loading="lazy" width="700" height="565" />
                  </div>
                </a>
                <div class="mt-5">
                  <div class="flex items-start justify-between gap-3">
                    <h3 class="min-h-10 text-sm font-medium leading-5 text-ink"><a class="hover:underline" href={`/products/${product.slug}/`}>{product.name}</a></h3>
                    <a class="grid h-10 w-10 shrink-0 place-items-center rounded-full bg-aqua text-ink transition hover:bg-ink hover:text-white" href="/contact/" aria-label={`Solicitar informacion sobre ${product.name}`}><ShoppingBag size={17} /></a>
                  </div>
                  <div class="mt-3 flex items-center gap-2 text-sm">
                    <span class="font-semibold text-ink">{product.price}</span>
                    {product.compareAtPrice && <span class="text-muted line-through">{product.compareAtPrice}</span>}
                  </div>
                  {product.colors.length > 0 && (
                    <div class="mt-4 flex gap-3" aria-label="Colores disponibles">
                      {product.colors.slice(0, 6).map((color, index) => <span class={`h-7 w-7 rounded-full border ${index === 0 ? 'border-ink ring-2 ring-ink/20' : 'border-ink/10'}`} style={`background-color: ${color.hex}`} title={color.name}></span>)}
                    </div>
                  )}
                  <a class="mt-5 hidden min-h-11 items-center justify-between rounded-pill border border-ink/50 px-5 text-xs font-black uppercase tracking-wide transition hover:bg-ink hover:text-white lg:flex" href={`/products/${product.slug}/`}>
                    Ver detalle
                    <span class="grid h-8 w-8 place-items-center rounded-full border border-current text-lg leading-none">↗</span>
                  </a>
                </div>
              </article>
            );
          })}
        </div>
      </div>

      <div class="mt-6 hidden justify-center gap-4 lg:flex">
        <button class="product-carousel-prev inline-flex h-8 min-w-16 items-center justify-center rounded-pill border border-ink/20 bg-white text-2xl leading-none transition hover:border-ink hover:bg-sand" type="button" aria-label="Productos anteriores">←</button>
        <button class="product-carousel-next inline-flex h-8 min-w-16 items-center justify-center rounded-pill border border-ink/20 bg-white text-2xl leading-none transition hover:border-ink hover:bg-sand" type="button" aria-label="Productos siguientes">→</button>
      </div>
    </section>
  </Container>

  <script is:inline>
    const productSection = document.querySelector('[data-product-section]');
    const productCarousel = productSection?.querySelector('.product-carousel');
    const productFilters = productSection?.querySelectorAll('[data-product-filter]') ?? [];
    const productCards = productSection?.querySelectorAll('[data-product-card]') ?? [];
    const productPreviousButton = productSection?.querySelector('.product-carousel-prev');
    const productNextButton = productSection?.querySelector('.product-carousel-next');

    const scrollProducts = (direction) => {
      if (!productCarousel) return;
      const firstVisibleCard = productCarousel.querySelector('[data-product-card]:not(.hidden)');
      const distance = firstVisibleCard ? firstVisibleCard.getBoundingClientRect().width + 32 : 392;
      productCarousel.scrollBy({ left: direction * distance, behavior: 'smooth' });
    };

    const setProductCategory = (category) => {
      productFilters.forEach((filter) => {
        const isActive = filter.getAttribute('data-product-filter') === category;
        filter.setAttribute('aria-selected', String(isActive));
        filter.classList.toggle('border-aqua', isActive);
        filter.classList.toggle('bg-aqua', isActive);
        filter.classList.toggle('text-ink', isActive);
        filter.classList.toggle('border-ink/30', !isActive);
        filter.classList.toggle('bg-white', !isActive);
        filter.classList.toggle('text-muted', !isActive);
      });

      productCards.forEach((card) => {
        const categories = card.getAttribute('data-product-categories') ?? '';
        card.classList.toggle('hidden', !categories.split(' ').includes(category));
      });

      productCarousel?.scrollTo({ left: 0, behavior: 'smooth' });
    };

    productFilters.forEach((filter) => {
      filter.addEventListener('click', () => {
        const category = filter.getAttribute('data-product-filter');
        if (category) setProductCategory(category);
      });
    });

    productPreviousButton?.addEventListener('click', () => scrollProducts(-1));
    productNextButton?.addEventListener('click', () => scrollProducts(1));
  </script>

  <section class="relative mt-6 overflow-hidden rounded-t-[2.4rem] bg-aqua px-5 py-16 sm:px-8 md:py-20 lg:mt-10 lg:rounded-t-[3rem] lg:px-12">
    <div class="mx-auto max-w-[1800px]">
      <h2 class="font-display text-2xl font-black uppercase tracking-wide text-ink md:text-4xl">Comparte con nosotros #MilaproHome</h2>
      <div class="relative mt-14">
        <button class="instagram-carousel-prev absolute left-1 top-1/2 z-10 grid h-10 w-10 -translate-y-1/2 place-items-center rounded-full bg-white/90 text-ink shadow-lg ring-1 ring-ink/10 transition hover:scale-105 hover:bg-white md:left-[24%]" type="button" aria-label="Video anterior">
          <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m15 18-6-6 6-6"></path></svg>
        </button>
        <div class="instagram-carousel mx-auto flex max-w-[1080px] snap-x snap-mandatory gap-3 overflow-x-auto pb-2 scroll-smooth lg:gap-4" tabindex="0" aria-label="Videos de Instagram de Milapro Home">
          {instagramReels.map((reel, index) => (
            <a
              class="group relative aspect-[9/16] w-[44vw] max-w-[190px] shrink-0 snap-start overflow-hidden rounded-xl bg-ink shadow-sm ring-1 ring-ink/10 transition duration-300 hover:-translate-y-1 hover:shadow-xl sm:w-[180px] lg:w-[190px]"
              href={reel.url}
              target="_blank"
              rel="noreferrer"
              aria-label={`Ver reel ${index + 1} de Milapro Home en Instagram`}
            >
              <img class="h-full w-full object-cover transition duration-500 group-hover:scale-105" src={reel.thumbnail} alt={`Thumbnail del reel ${index + 1} de Milapro Home`} loading="lazy" width="720" height="1280" />
              <span class="absolute inset-0 bg-gradient-to-t from-ink/85 via-ink/10 to-ink/20" aria-hidden="true"></span>
              <span class="absolute left-2 top-2 rounded-full bg-white/75 px-2 py-1 text-[10px] font-bold text-ink shadow-sm backdrop-blur">@milaprohome.mid</span>
              <span class="absolute right-2 top-2 grid h-6 w-6 place-items-center rounded-full bg-white/70 text-ink shadow-sm backdrop-blur" aria-hidden="true">
                <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"></path></svg>
              </span>
            </a>
          ))}
        </div>
        <button class="instagram-carousel-next absolute right-1 top-1/2 z-10 grid h-10 w-10 -translate-y-1/2 place-items-center rounded-full bg-white/90 text-ink shadow-lg ring-1 ring-ink/10 transition hover:scale-105 hover:bg-white md:right-[24%]" type="button" aria-label="Video siguiente">
          <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m9 18 6-6-6-6"></path></svg>
        </button>
      </div>
    </div>
  </section>

  <script is:inline>
    const carousel = document.querySelector('.instagram-carousel');
    const previousButton = document.querySelector('.instagram-carousel-prev');
    const nextButton = document.querySelector('.instagram-carousel-next');

    const scrollCarousel = (direction) => {
      if (!carousel) return;
      const firstCard = carousel.querySelector('a');
      const distance = firstCard ? firstCard.getBoundingClientRect().width + 12 : 182;
      carousel.scrollBy({ left: direction * distance, behavior: 'smooth' });
    };

    previousButton?.addEventListener('click', () => scrollCarousel(-1));
    nextButton?.addEventListener('click', () => scrollCarousel(1));
  </script>

  <Container>
    <section class="py-12 lg:py-16">
      <div class="flex flex-wrap items-end justify-between gap-3">
        <SectionHeading title="Blogs e inspiraciones" description="Consejos para elegir materiales, crear sombra y transformar espacios exteriores con soluciones funcionales." />
        <Button href="/blogs/" class="min-h-9 px-5 text-xs lg:min-h-11 lg:px-6 lg:text-sm">Ver todo</Button>
      </div>
      <div class="mt-3 grid gap-8 md:grid-cols-3 lg:mt-8">
        {blogCards.map((card) => (
          <article>
            <img class="aspect-[4/3] rounded-xl object-cover" src={card.image} alt={card.title} loading="lazy" width="800" height="600" />
            <p class="mt-4 text-xs text-muted">{card.category}</p>
            <h3 class="mt-2 text-lg font-bold text-ink"><a class="transition hover:text-cocoa" href={`/blogs/${card.slug}/`}>{card.title}</a></h3>
            <p class="mt-2 text-sm leading-6 text-muted">{card.excerpt}</p>
          </article>
        ))}
      </div>
    </section>

    <section id="reviews" class="py-12 lg:py-16">
      <div class="px-2 lg:flex lg:items-center lg:justify-between lg:gap-6 lg:px-0">
        <h2 class="font-display text-[26px] font-light uppercase tracking-[0.04em] text-ink sm:text-5xl lg:text-6xl lg:tracking-[0.08em]">Opiniones de clientes</h2>
        <Button href="/reviews/" variant="secondary" class="hidden lg:inline-flex">Ver todo</Button>
      </div>
      <div class="relative left-1/2 mt-6 w-screen -translate-x-1/2 rounded-b-[3rem] bg-[#f1f1f1] px-5 py-10 sm:px-8 md:py-16 lg:rounded-b-[4rem]" data-review-carousel>
        <div class="mx-auto grid max-w-[1180px] gap-10 md:grid-cols-[minmax(0,1.08fr)_minmax(320px,0.92fr)] md:items-center lg:gap-28">
          <img class="review-image aspect-[1.2/1] w-full object-cover md:aspect-[1.22/1]" src={featuredReviews[0].image} alt={`Ambiente exterior de ${featuredReviews[0].name}`} loading="lazy" width="900" height="675" />
          <div class="flex flex-col justify-center">
            <p class="review-name font-medium text-muted">@ {featuredReviews[0].name}</p>
            <p class="review-rating mt-5 text-4xl leading-none text-orange-600" aria-label={`${featuredReviews[0].rating} estrellas`}>{'★'.repeat(featuredReviews[0].rating)}</p>
            <h3 class="review-product mt-5 font-black uppercase text-ink">{featuredReviews[0].product}</h3>
            <p class="review-quote mt-5 max-w-xl text-base leading-7 text-muted">{featuredReviews[0].quote}</p>
            <div class="-order-1 mb-2 flex gap-4 md:order-none md:mb-0 md:mt-7">
              <button class="review-prev inline-flex h-8 min-w-16 items-center justify-center rounded-pill border border-ink/20 bg-white text-2xl leading-none transition hover:border-ink hover:bg-sand" type="button" aria-label="Opinión anterior">←</button>
              <button class="review-next inline-flex h-8 min-w-16 items-center justify-center rounded-pill border border-ink/20 bg-white text-2xl leading-none transition hover:border-ink hover:bg-sand" type="button" aria-label="Opinión siguiente">→</button>
            </div>
          </div>
        </div>
      </div>
    </section>
  </Container>
</MainLayout>

<script define:vars={{ featuredReviews }}>
  const reviewCarousel = document.querySelector('[data-review-carousel]');

  if (reviewCarousel && featuredReviews.length > 0) {
    const image = reviewCarousel.querySelector('.review-image');
    const name = reviewCarousel.querySelector('.review-name');
    const rating = reviewCarousel.querySelector('.review-rating');
    const product = reviewCarousel.querySelector('.review-product');
    const quote = reviewCarousel.querySelector('.review-quote');
    const previousButton = reviewCarousel.querySelector('.review-prev');
    const nextButton = reviewCarousel.querySelector('.review-next');
    let activeIndex = 0;

    const renderReview = () => {
      const review = featuredReviews[activeIndex];
      image.src = review.image;
      image.alt = `Ambiente exterior de ${review.name}`;
      name.textContent = `@ ${review.name}`;
      rating.textContent = '★'.repeat(review.rating);
      rating.setAttribute('aria-label', `${review.rating} estrellas`);
      product.textContent = review.product;
      quote.textContent = review.quote;
    };

    previousButton?.addEventListener('click', () => {
      activeIndex = (activeIndex - 1 + featuredReviews.length) % featuredReviews.length;
      renderReview();
    });

    nextButton?.addEventListener('click', () => {
      activeIndex = (activeIndex + 1) % featuredReviews.length;
      renderReview();
    });
  }
</script>
