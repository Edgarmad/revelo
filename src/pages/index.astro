---
import Container from '@/components/common/Container.astro';
import Button from '@/components/common/Button.astro';
import SectionHeading from '@/components/common/SectionHeading.astro';
import CategoryCard from '@/components/category/CategoryCard.astro';
import ProductGrid from '@/components/product/ProductGrid.astro';
import ContactCallout from '@/components/sections/ContactCallout.astro';
import MainLayout from '@/layouts/MainLayout.astro';
import { getFeaturedCategories } from '@/services/categoryService';
import { getFeaturedProducts } from '@/services/productService';
import { blogCards, testimonials } from '@/data/siteContent';
import { CreditCard, RotateCcw, ShieldCheck, Truck } from 'lucide-astro';
import bgSrc from '@/styles/images/bg.webp';

const categories = getFeaturedCategories();
const products = getFeaturedProducts(4);
const testimonial = testimonials[0];
const instagramReels = [
  { url: 'https://www.instagram.com/milaprohome.mid/reel/DbE5EoXtMei/', tone: 'from-stone-200 via-stone-100 to-cocoa/50' },
  { url: 'https://www.instagram.com/milaprohome.mid/reel/Da6HAhoJtuT/', tone: 'from-sand via-white to-aqua/30' },
  { url: 'https://www.instagram.com/milaprohome.mid/reel/DaLX89wR8Gn/', tone: 'from-cocoa/30 via-sand to-stone-200' },
  { url: 'https://www.instagram.com/milaprohome.mid/reel/DTl0X5QD12n/', tone: 'from-zinc-200 via-sand to-cocoa/40' },
  { url: 'https://www.instagram.com/milaprohome.mid/reel/DUJOXy7kdGP/', tone: 'from-white via-sand to-aqua/40' },
  { url: 'https://www.instagram.com/milaprohome.mid/reel/DRU30uZgfVq/', tone: 'from-stone-100 via-white to-zinc-300' },
  { url: 'https://www.instagram.com/milaprohome.mid/reel/DPouY0NklzU/', tone: 'from-cocoa/40 via-sand to-white' },
  { url: 'https://www.instagram.com/milaprohome.mid/reel/DPUBKIkjWwX/', tone: 'from-aqua/30 via-white to-sand' },
  { url: 'https://www.instagram.com/milaprohome.mid/reel/DOWnTiViefZ/', tone: 'from-zinc-300 via-stone-100 to-cocoa/30' },
];
---

<MainLayout title="Milapro Home | Catalogo visual de muebles modulares" description="MVP visual de catalogo premium inspirado en Milapro Home, con sofas modulares, reclinables y muebles para sala.">
  <section class="relative min-h-[520px] overflow-hidden">
    <img class="absolute inset-0 h-full w-full object-none" src={bgSrc} alt="Comedor exterior frente al mar" width="1800" height="1000" />
    <div class="absolute inset-0"></div>
    <Container class="relative grid min-h-[520px] place-items-center py-20 text-center text-white">
      <div>
        <h1 class="font-display text-5xl font-black uppercase leading-none tracking-tight sm:text-7xl lg:text-8xl">Summer Sale</h1>
        <p class="mt-2 text-3xl font-light uppercase sm:text-5xl">Hasta 50% Off</p>
        <Button href="/products/" class="mt-6">Shop now</Button>
      </div>
    </Container>
  </section>

  <Container>
    <section class="grid border-b border-ink/10 py-10 sm:grid-cols-2 lg:grid-cols-4">
      {[
        { icon: Truck, label: 'Free shipping' },
        { icon: ShieldCheck, label: 'Three-year warranty' },
        { icon: CreditCard, label: 'Installment payments' },
        { icon: RotateCcw, label: '30-day returns' },
      ].map((benefit) => (
        <div class="flex flex-col items-center gap-3 border-ink/10 py-6 text-center lg:border-r last:border-r-0">
          <benefit.icon class="text-aqua" size={30} />
          <p class="text-sm font-semibold uppercase tracking-wide text-muted">{benefit.label}</p>
        </div>
      ))}
    </section>

    <section class="py-14">
      <h2 class="font-display text-4xl font-light tracking-tight text-ink sm:text-5xl">Milapro Home - Make Life Better</h2>
      <p class="mt-10 text-2xl font-light uppercase tracking-wide text-cocoa">Shop by category</p>
      <div class="mt-10 grid gap-8 sm:grid-cols-2 lg:grid-cols-4">
        {categories.map((category) => <CategoryCard category={category} />)}
      </div>
    </section>

    <section class="pb-16">
      <div class="flex flex-wrap items-end justify-between gap-6">
        <SectionHeading title="Our Products" description="Colecciones visuales listas para adaptar a catalogo real en fases posteriores." />
        <Button href="/products/" variant="secondary">View all</Button>
      </div>
      <div class="mt-8 flex flex-wrap gap-3">
        {['Rubik V - Collection', 'Reclining Modular Couch', 'Best Value', 'Rubik III - Collection', 'Cabik I - Collection'].map((item, index) => <span class={`rounded-pill px-4 py-2 text-xs font-semibold ${index === 0 ? 'bg-aqua text-ink' : 'bg-sand text-muted'}`}>{item}</span>)}
      </div>
      <div class="mt-8"><ProductGrid products={products} /></div>
    </section>
  </Container>

  <Container>
    <section class="rounded-[2.4rem] bg-aqua p-6 md:p-10">
      <div class="flex flex-wrap items-end justify-between gap-4">
        <h2 class="font-display text-2xl font-black uppercase md:text-3xl">Share with us #Milapro Home</h2>
        <div class="flex gap-2" aria-label="Controles del carrusel de Instagram">
          <button class="instagram-carousel-prev rounded-full bg-ink px-4 py-2 text-sm font-semibold text-white transition hover:bg-ink/80" type="button" aria-label="Video anterior">Prev</button>
          <button class="instagram-carousel-next rounded-full bg-ink px-4 py-2 text-sm font-semibold text-white transition hover:bg-ink/80" type="button" aria-label="Video siguiente">Next</button>
        </div>
      </div>
      <div class="instagram-carousel mt-8 flex snap-x snap-mandatory gap-3 overflow-x-auto pb-4 scroll-smooth md:justify-center" tabindex="0" aria-label="Videos de Instagram de Milapro Home">
        {instagramReels.map((reel, index) => (
          <a
            class={`group relative aspect-[9/16] w-[44vw] max-w-[170px] shrink-0 snap-start overflow-hidden rounded-xl bg-gradient-to-br ${reel.tone} shadow-sm ring-1 ring-ink/10 transition duration-300 hover:-translate-y-1 hover:shadow-xl sm:w-[150px] lg:w-[170px]`}
            href={reel.url}
            target="_blank"
            rel="noreferrer"
            aria-label={`Ver reel ${index + 1} de Milapro Home en Instagram`}
          >
            <span class="absolute left-2 top-2 rounded-full bg-white/75 px-2 py-1 text-[10px] font-bold text-ink shadow-sm backdrop-blur">@milaprohome.mid</span>
            <span class="absolute right-2 top-2 grid h-6 w-6 place-items-center rounded-full bg-white/70 text-ink shadow-sm backdrop-blur" aria-hidden="true">
              <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"></path></svg>
            </span>
            <span class="absolute inset-x-0 bottom-0 bg-gradient-to-t from-ink/75 to-transparent p-3 pt-14 text-white">
              <span class="block text-xs font-semibold uppercase tracking-wide">Instagram Reel</span>
              <span class="mt-1 block text-lg font-black leading-none">#{String(index + 1).padStart(2, '0')}</span>
            </span>
          </a>
        ))}
      </div>
    </section>
  </Container>

  <script is:inline>
    const carousel = document.querySelector('.instagram-carousel');
    const previousButton = document.querySelector('.instagram-carousel-prev');
    const nextButton = document.querySelector('.instagram-carousel-next');

    const scrollCarousel = (direction) => {
      if (!carousel) return;
      const firstCard = carousel.querySelector('a');
      const distance = firstCard ? firstCard.getBoundingClientRect().width + 12 : 182;
      carousel.scrollBy({ left: direction * distance, behavior: 'smooth' });
    };

    previousButton?.addEventListener('click', () => scrollCarousel(-1));
    nextButton?.addEventListener('click', () => scrollCarousel(1));
  </script>

  <Container>
    <section class="py-16">
      <div class="flex flex-wrap items-end justify-between gap-6">
        <SectionHeading title="Blogs & Inspirations" description="Discover our freshest event updates to unveil exciting dimensions of play with modular sofas." />
        <Button href="/about/">View all</Button>
      </div>
      <div class="mt-8 grid gap-8 md:grid-cols-3">
        {blogCards.map((card) => (
          <article>
            <img class="aspect-[4/3] rounded-xl object-cover" src={card.image} alt={card.title} loading="lazy" width="800" height="600" />
            <p class="mt-4 text-xs text-muted">{card.category}</p>
            <h3 class="mt-2 text-lg font-bold text-ink">{card.title}</h3>
            <p class="mt-2 text-sm leading-6 text-muted">{card.excerpt}</p>
          </article>
        ))}
      </div>
    </section>

    <section id="reviews" class="py-12">
      <div class="flex flex-wrap items-center justify-between gap-6 px-2">
        <h2 class="font-display text-4xl font-light uppercase tracking-tight">Voices of Customer</h2>
        <Button href="/products/" variant="secondary">View all</Button>
      </div>
      <div class="mt-6 grid gap-10 rounded-b-[2rem] bg-sand p-8 md:grid-cols-2 md:p-12">
        <img class="aspect-[4/3] rounded-xl object-cover" src={testimonial.image} alt={`Sala de ${testimonial.name}`} loading="lazy" width="900" height="675" />
        <div class="flex flex-col justify-center">
          <p class="font-semibold text-muted">@ {testimonial.name}</p>
          <p class="mt-4 text-3xl text-orange-500" aria-label={`${testimonial.rating} estrellas`}>★★★★★</p>
          <h3 class="mt-3 font-bold uppercase">{testimonial.product}</h3>
          <p class="mt-5 max-w-xl leading-7 text-muted">{testimonial.quote}</p>
        </div>
      </div>
    </section>

    <ContactCallout />
  </Container>
</MainLayout>
