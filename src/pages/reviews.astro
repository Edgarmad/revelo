---
import Button from '@/components/common/Button.astro';
import Container from '@/components/common/Container.astro';
import SectionHeading from '@/components/common/SectionHeading.astro';
import Breadcrumbs from '@/components/common/Breadcrumbs.astro';
import MainLayout from '@/layouts/MainLayout.astro';
import { customerReviews } from '@/data/siteContent';
---

<MainLayout title="Opiniones de clientes | Milapro Home" description="Opiniones positivas de clientes Milapro Home sobre muebles de exterior, pérgolas, sombrillas y proyectos a la medida.">
  <Container class="py-14">
    <Breadcrumbs items={[{ label: 'Inicio', href: '/' }, { label: 'Opiniones de clientes' }]} />

    <section class="mt-8 rounded-[2.4rem] bg-sand p-8 md:p-12">
      <div class="flex flex-wrap items-end justify-between gap-8">
        <div class="max-w-3xl">
          <SectionHeading eyebrow="Opiniones" title="Opiniones de clientes" description="Experiencias reales sobre comodidad, resistencia y diseño en terrazas, jardines y proyectos comerciales." />
        </div>
        <Button href="/contact/">Solicitar asesoría</Button>
      </div>
    </section>

    <section class="mt-12 grid gap-8 md:grid-cols-2">
      {customerReviews.map((review) => (
        <article class="grid overflow-hidden rounded-2xl bg-white shadow-sm ring-1 ring-ink/10 lg:grid-cols-[0.9fr_1.1fr]">
          <img class="h-full min-h-72 w-full object-cover" src={review.image} alt={`Ambiente exterior de ${review.name}`} loading="lazy" width="900" height="675" />
          <div class="flex flex-col justify-center p-7">
            <p class="font-semibold text-muted">@ {review.name}</p>
            <p class="mt-4 text-3xl text-orange-500" aria-label={`${review.rating} estrellas`}>{'★'.repeat(review.rating)}</p>
            <h2 class="mt-3 font-bold uppercase text-ink">{review.product}</h2>
            <p class="mt-5 leading-7 text-muted">{review.quote}</p>
          </div>
        </article>
      ))}
    </section>
  </Container>
</MainLayout>
